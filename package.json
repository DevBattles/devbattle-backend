{
  "name": "devbattle-auth-backend",
  "version": "1.0.0",
  "description": "Production-ready authentication backend for DevBattle using Node.js, Express, Drizzle ORM, and Supabase",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "node drizzle/migrate.js",
    "db:studio": "drizzle-kit studio",
    "db:seed": "node scripts/seed.js"
  },
  "keywords": [
    "express",
    "drizzle",
    "supabase",
    "auth",
    "jwt",
    "postgres"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.30.10",
    "express": "^4.19.2",
    "express-rate-limit": "^7.2.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "postgres": "^3.4.4",
    "winston": "^3.13.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "drizzle-kit": "^0.21.4",
    "nodemon": "^3.1.0"
  }
}
